{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/gitIntegration/schedules/1.0.0/schema.json",
  "schedules": [
    {
      "enabled": true,
      "jobType": "Execute",
      "configuration": {
        "type": "Weekly",
        "startDateTime": "2026-07-15T00:00:00",
        "endDateTime": "2099-12-31T23:59:00",
        "localTimeZoneId": "Pacific Standard Time",
        "times": [
          "21:30"
        ],
        "weekdays": [
          "Sunday",
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday"
        ]
      }
    }
  ]
}